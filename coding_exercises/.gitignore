# Notebook execution artifacts — kept out of the repo so we ship only the
# notebook itself + its build script. All datasets in the exercises are
# either synthetic (generated in-cell) or fetched from public URLs at runtime;
# nothing should be committed.

# Per-lecture data caches (Scanpy / Pfam / UniProt fetches, etc.)
lecture-*/data/

# Build / executed artifacts
lecture-*/executed.ipynb
lecture-*/.ipynb_checkpoints/
lecture-*/__pycache__/

# Editor state
*.swp
.DS_Store
